Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: Capella Agent Requirements
Bundle-SymbolicName: com.capellaagent.requirements;singleton:=true
Bundle-Version: 1.0.0.qualifier
Bundle-Vendor: CapellaAgent
Bundle-RequiredExecutionEnvironment: JavaSE-17
Bundle-ActivationPolicy: lazy
Bundle-Activator: com.capellaagent.requirements.RequirementsActivator
Require-Bundle: com.capellaagent.core;bundle-version="1.0.0",
 com.capellaagent.modelchat;bundle-version="1.0.0",
 org.eclipse.core.runtime;bundle-version="3.26.0",
 org.eclipse.emf.ecore,
 org.eclipse.sirius,
 org.polarsys.kitalpha.vp.requirements;resolution:=optional
Bundle-ClassPath: .,
 lib/poi-5.2.5.jar,
 lib/poi-ooxml-5.2.5.jar,
 lib/commons-compress-1.25.0.jar,
 lib/xmlbeans-5.2.0.jar,
 lib/commons-io-2.15.1.jar,
 lib/curvesapi-1.08.jar,
 lib/commons-math3-3.6.1.jar,
 lib/commons-collections4-4.4.jar,
 lib/SparseBitSet-1.3.jar
Export-Package: com.capellaagent.requirements
