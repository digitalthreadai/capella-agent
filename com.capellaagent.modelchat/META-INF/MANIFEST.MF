Manifest-Version: 1.0
Bundle-ManifestVersion: 2
Bundle-Name: Capella Agent Model Chat
Bundle-SymbolicName: com.capellaagent.modelchat;singleton:=true
Bundle-Version: 1.0.0.qualifier
Bundle-Activator: com.capellaagent.modelchat.ModelChatActivator
Bundle-Vendor: CapellaAgent
Bundle-RequiredExecutionEnvironment: JavaSE-17
Bundle-ActivationPolicy: lazy
Require-Bundle: com.capellaagent.core;bundle-version="1.0.0",
 org.eclipse.core.runtime;bundle-version="3.26.0",
 org.eclipse.emf.transaction;bundle-version="1.9.0",
 org.eclipse.sirius;bundle-version="7.0.0",
 com.google.gson;bundle-version="2.10.0",
 org.eclipse.emf.ecore;bundle-version="2.29.0",
 org.eclipse.core.resources;bundle-version="3.18.0"
Export-Package: com.capellaagent.modelchat,
 com.capellaagent.modelchat.tools.read,
 com.capellaagent.modelchat.tools.write,
 com.capellaagent.modelchat.tools.diagram
Import-Package: org.eclipse.sirius.business.api.session,
 org.eclipse.sirius.business.api.dialect,
 org.eclipse.sirius.viewpoint,
 org.eclipse.emf.transaction,
 org.eclipse.emf.transaction.impl
